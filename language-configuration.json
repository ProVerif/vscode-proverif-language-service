{
    "comments": {
        // there is only a block comment in ProVerif
        "blockComment": [ "(*", "*)" ]
    },
    // symbols used as brackets
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    // symbols that are auto closed when typing
    // all patterns that occurr in ProVerif
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["(*", "*)"],
    ],
    // symbols that can be used to surround a selection
    // same as autoClosingPairs, but without the comment bracket
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""]
    ],
    // indents
    "indentationRules": {
        // indent on brackets {([ equal / diff = <> and implication/equivalence ==> <-> <=>
        "increaseIndentPattern": "^.*({|\\(|\\[|=|<>|==>|<->|<=>)$",
        // decrease indent when lib ends (commented as sometimes surprising)
        // "decreaseIndentPattern": "^.*\\.$"
    },
    // indents based on more complex rules
    "onEnterRules": [
        {
            // indent after first semicolon for lib rules 
            "beforeText": "^\\s*(nounif|noselect|select|query|noninterf|not|elimtrue|lemma|axiom|restriction).*?;$",
            "action": { "indent": "indent" }
        }
    ]
}