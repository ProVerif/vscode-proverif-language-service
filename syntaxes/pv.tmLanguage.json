{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "pv",
	"scopeName": "source.pv",
	"fileTypes": ["pv", "pvl", "pcv"],
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#lib" }
	],
	"repository": {
		"lib": {
			"patterns": [
				{
					"//comment": "FUN",
					"begin": "(fun)(?!\\S)",
					"end": "(\\.)",
					"beginCaptures": { 
						"1": { "name": "keyword.control.proverif" }
					},
					"endCaptures": { "1": { "name": "keyword.proverif" } },
					"patterns": [
					  { 
						"begin": "([a-zA-Z][a-zA-Z'0-9_]*)",
						"end": "(:)",
						"beginCaptures": { 
							"1": { "name": "entity.name.type.proverif" } 
						},
						"endCaptures": { 
							"1": { "name": "keyword.proverif" } 
						}
					  }
					]
				}
			]
		},
		"comments": {
		  "patterns": [
			{
			  "name": "comment.line.documentation.pv",
			  "begin": "\\(\\*",
			  "end": "\\*\\)",
			  "patterns": [{ "include": "#commentContents" }]
			}
		  ]
		},
		"commentContents": {
		  "patterns": [
			{
			  "match": "\\b(TODO|FIXME|XXX|NOTE)\\b:?",
			  "name": "keyword.todo.pv"
			}
		  ]
		}
	}
}